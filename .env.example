# Copy this file to .env and fill in values before running docker compose.
# Never commit .env to version control.

# Flask backend secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-value

# Grafana admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-use-a-strong-password
